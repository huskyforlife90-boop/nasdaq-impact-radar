# ──────────────────────────────────────────────────────────────
# FRONTEND (Vite) — copy to .env or .env.local in project root
# ──────────────────────────────────────────────────────────────

# Demo mode. When "true", every adapter serves clearly-labeled mock data
# and the app runs with zero credentials. Set to "false" once the relay
# is running and at least one live source is configured.
VITE_DEMO_MODE=true

# Base URL of the backend relay (server/index.js). In local dev you can
# leave this empty — Vite proxies /api/* to http://localhost:8787.
# In production set it to your deployed relay, e.g. https://relay.yourhost.com
VITE_RELAY_URL=

# Polling interval in seconds for the catalyst feed (min 10).
VITE_POLL_SECONDS=30

# ──────────────────────────────────────────────────────────────
# RELAY SERVER — copy to server/.env (loaded by server/index.js)
# ──────────────────────────────────────────────────────────────

PORT=8787

# Unusual Whales — OFFICIAL API ONLY. Requires a paid API subscription.
# Get a token at https://unusualwhales.com/api  → goes in the header
# "Authorization: Bearer <token>". Leave blank to keep this source mocked.
UW_API_KEY=

# Generic market-news wire. The relay ships with a Finnhub adapter
# (free tier available at https://finnhub.io). Leave blank to keep mocked.
FINNHUB_API_KEY=

# StockMKTNewz is an X (Twitter) account. There is NO free public API for
# X timelines. If you have paid X API v2 access, put your bearer token here
# and the relay will use GET /2/users/:id/tweets. Otherwise this source
# stays a clean scaffold + mock. Do NOT scrape X — it violates their ToS.
X_BEARER_TOKEN=
STOCKMKTNEWZ_USER_ID=

# FRED (free key, https://fred.stlouisfed.org/docs/api/api_key.html)
# used for US10Y / DXY context. Leave blank to keep context mocked.
FRED_API_KEY=
